generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Entity {
  id               String            @id @default(cuid())
  code             String            @unique
  name             String
  legalName        String?
  pfCode           String?
  esiCode          String?
  ptCode           String?
  gstin            String?
  locations        Location[]
  employees        Employee[]
  attendanceMonths AttendanceMonth[]
  payrollRuns      PayrollRun[]
  leaveTypes             LeaveType[]
  leaveRequests          LeaveRequest[]
  complianceFilings      ComplianceFiling[]
  investmentDeclarations InvestmentDeclaration[]
  createdAt              DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

model Location {
  id        String     @id @default(cuid())
  code      String
  name      String
  entityId  String
  entity    Entity     @relation(fields: [entityId], references: [id])
  employees Employee[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@unique([entityId, code])
}

model Department {
  id             String          @id @default(cuid())
  name           String          @unique
  subDepartments SubDepartment[]
  employees      Employee[]
  createdAt      DateTime        @default(now())
}

model SubDepartment {
  id           String     @id @default(cuid())
  name         String
  departmentId String
  department   Department @relation(fields: [departmentId], references: [id])
  employees    Employee[]
  createdAt    DateTime   @default(now())

  @@unique([departmentId, name])
}

model Designation {
  id        String     @id @default(cuid())
  name      String     @unique
  employees Employee[]
  createdAt DateTime   @default(now())
}

model ShiftCode {
  id        String     @id @default(cuid())
  code      String     @unique
  name      String
  startTime String?
  endTime   String?
  employees Employee[]
  createdAt DateTime   @default(now())
}

model Employee {
  id               String    @id @default(cuid())
  employeeCode     String    @unique
  fullName         String
  careOfName       String?
  careOfRelation   String?
  dateOfBirth      DateTime?
  gender           String?
  bloodGroup       String?
  aadhaarNumber    String?
  panNumber        String?
  contact1         String?
  contact2         String?
  presentAddress   String?
  permanentAddress String?
  profilePhotoUrl  String?

  bankAccountNo String?
  bankName      String?
  bankIfsc      String?
  bankBranch    String?

  uanNumber String?
  uanStatus String @default("NOT_GENERATED")
  esiNumber String?
  esiStatus String @default("NOT_GENERATED")

  entityId             String
  entity               Entity         @relation(fields: [entityId], references: [id])
  locationId           String
  location             Location       @relation(fields: [locationId], references: [id])
  departmentId         String
  department           Department     @relation(fields: [departmentId], references: [id])
  subDepartmentId      String?
  subDepartment        SubDepartment? @relation(fields: [subDepartmentId], references: [id])
  designationId        String
  designation          Designation    @relation(fields: [designationId], references: [id])
  shiftCodeId          String?
  shiftCode            ShiftCode?     @relation(fields: [shiftCodeId], references: [id])
  dateOfJoining        DateTime
  dateOfJoiningCurrent DateTime?
  bonusMonth           Int?
  appraisalDate        DateTime?
  status               String         @default("ACTIVE")
  separationDate       DateTime?

  salary       Decimal @default(0) @db.Decimal(12, 2)
  basic        Decimal @default(0) @db.Decimal(12, 2)
  hra          Decimal @default(0) @db.Decimal(12, 2)
  specialAllow Decimal @default(0) @db.Decimal(12, 2)
  travelAllow  Decimal @default(0) @db.Decimal(12, 2)

  attendanceRecords      AttendanceRecord[]
  payrollDetails         PayrollDetail[]
  advanceEntries         AdvanceEntry[]
  loanAccounts           LoanAccount[]
  leaveBalances          LeaveBalance[]
  leaveRequests          LeaveRequest[]
  investmentDeclarations InvestmentDeclaration[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([entityId])
  @@index([locationId])
  @@index([departmentId])
  @@index([status])
}

model AttendanceMonth {
  id       String   @id @default(cuid())
  year     Int
  month    Int
  entityId String
  entity   Entity   @relation(fields: [entityId], references: [id])
  status   String   @default("OPEN")
  lockedAt DateTime?
  lockedBy String?
  records  AttendanceRecord[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([year, month, entityId])
}

model AttendanceRecord {
  id                String          @id @default(cuid())
  attendanceMonthId String
  attendanceMonth   AttendanceMonth @relation(fields: [attendanceMonthId], references: [id])
  employeeId        String
  employee          Employee        @relation(fields: [employeeId], references: [id])

  day1  String?
  day2  String?
  day3  String?
  day4  String?
  day5  String?
  day6  String?
  day7  String?
  day8  String?
  day9  String?
  day10 String?
  day11 String?
  day12 String?
  day13 String?
  day14 String?
  day15 String?
  day16 String?
  day17 String?
  day18 String?
  day19 String?
  day20 String?
  day21 String?
  day22 String?
  day23 String?
  day24 String?
  day25 String?
  day26 String?
  day27 String?
  day28 String?
  day29 String?
  day30 String?
  day31 String?

  workedDays  Decimal? @db.Decimal(5, 1)
  weekOffs    Int?
  otDays      Decimal? @db.Decimal(5, 1)
  payableDays Decimal? @db.Decimal(5, 1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([attendanceMonthId, employeeId])
  @@index([employeeId])
}

model Holiday {
  id        String   @id @default(cuid())
  date      DateTime @db.Date
  name      String
  entityId  String?
  createdAt DateTime @default(now())

  @@unique([date, entityId])
}

model PayrollRun {
  id             String    @id @default(cuid())
  entityId       String    @map("entity_id")
  year           Int
  month          Int
  status         String    @default("DRAFT")
  totalGross     Float     @default(0) @map("total_gross")
  totalDeductions Float    @default(0) @map("total_deductions")
  totalNet       Float     @default(0) @map("total_net")
  employeeCount  Int       @default(0) @map("employee_count")
  processedAt    DateTime? @map("processed_at")
  lockedAt       DateTime? @map("locked_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  entity         Entity          @relation(fields: [entityId], references: [id])
  details        PayrollDetail[]

  @@unique([entityId, year, month])
  @@map("payroll_runs")
}

model PayrollDetail {
  id              String @id @default(cuid())
  payrollRunId    String @map("payroll_run_id")
  employeeId      String @map("employee_id")

  // Attendance inputs
  payableDays     Float  @default(0) @map("payable_days")
  workedDays      Float  @default(0) @map("worked_days")
  otDays          Float  @default(0) @map("ot_days")
  leaveEncashDays Int    @default(0) @map("leave_encash_days")
  labourHoliday   Int    @default(0) @map("labour_holiday")

  // Salary base (snapshot from employee record at processing time)
  salary          Float  @default(0)
  basic           Float  @default(0)
  hra             Float  @default(0)
  specialAllowance Float @default(0) @map("special_allowance")
  bonus           Float  @default(0)
  ta              Float  @default(0)
  lec             Float  @default(0)
  perDaySalary    Float  @default(0) @map("per_day_salary")

  // Earned components
  earnedBasic     Float  @default(0) @map("earned_basic")
  earnedHra       Float  @default(0) @map("earned_hra")
  earnedSpecial   Float  @default(0) @map("earned_special")
  earnedOt        Float  @default(0) @map("earned_ot")
  earnedLeave     Float  @default(0) @map("earned_leave")
  earnedLabour    Float  @default(0) @map("earned_labour")
  earnedTa        Float  @default(0) @map("earned_ta")
  salaryArrears   Float  @default(0) @map("salary_arrears")
  grossSalary     Float  @default(0) @map("gross_salary")

  // Statutory deductions
  pfEmployee      Float  @default(0) @map("pf_employee")
  pfEmployer      Float  @default(0) @map("pf_employer")
  esiEmployee     Float  @default(0) @map("esi_employee")
  esiEmployer     Float  @default(0) @map("esi_employer")
  professionalTax Float  @default(0) @map("professional_tax")
  tds             Float  @default(0)

  // Other deductions
  uniformDeduction Float @default(0) @map("uniform_deduction")
  bankAdvance     Float  @default(0) @map("bank_advance")
  cashAdvance     Float  @default(0) @map("cash_advance")
  jifyAdvance     Float  @default(0) @map("jify_advance")
  loanEmi         Float  @default(0) @map("loan_emi")
  cashLoanEmi     Float  @default(0) @map("cash_loan_emi")

  totalDeductions Float  @default(0) @map("total_deductions")
  netSalary       Float  @default(0) @map("net_salary")

  // Employer cost
  gratuity        Float  @default(0)
  ctc             Float  @default(0)

  payrollRun      PayrollRun @relation(fields: [payrollRunId], references: [id])
  employee        Employee   @relation(fields: [employeeId], references: [id])

  @@unique([payrollRunId, employeeId])
  @@map("payroll_details")
}

model AdvanceEntry {
  id         String    @id @default(cuid())
  employeeId String    @map("employee_id")
  type       String
  amount     Float
  month      Int
  year       Int
  date       DateTime?
  remarks    String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  employee   Employee  @relation(fields: [employeeId], references: [id])

  @@index([employeeId])
  @@index([year, month])
  @@map("advance_entries")
}

model LoanAccount {
  id                 String   @id @default(cuid())
  employeeId         String   @map("employee_id")
  loanType           String   @map("loan_type")
  principalAmount    Float    @map("principal_amount")
  emiAmount          Float    @map("emi_amount")
  tenure             Int
  startMonth         Int      @map("start_month")
  startYear          Int      @map("start_year")
  totalPaid          Float    @default(0) @map("total_paid")
  outstandingBalance Float    @map("outstanding_balance")
  status             String   @default("ACTIVE")
  remarks            String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  employee           Employee @relation(fields: [employeeId], references: [id])

  @@index([employeeId])
  @@map("loan_accounts")
}

model LeaveType {
  id                 String   @id @default(cuid())
  entityId           String
  entity             Entity   @relation(fields: [entityId], references: [id])
  code               String
  name               String
  annualQuota        Int
  carryForwardMax    Int      @default(0)
  requiresApproval   Boolean  @default(true)
  applicableGender   String?
  maxConsecutiveDays Int?
  isPaid             Boolean  @default(true)
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  balances  LeaveBalance[]
  requests  LeaveRequest[]

  @@unique([entityId, code])
  @@map("leave_types")
}

model LeaveBalance {
  id          String    @id @default(cuid())
  employeeId  String
  employee    Employee  @relation(fields: [employeeId], references: [id])
  leaveTypeId String
  leaveType   LeaveType @relation(fields: [leaveTypeId], references: [id])
  year        Int
  opening     Float     @default(0)
  credited    Float     @default(0)
  used        Float     @default(0)
  balance     Float     @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([employeeId, leaveTypeId, year])
  @@map("leave_balances")
}

model LeaveRequest {
  id              String    @id @default(cuid())
  employeeId      String
  employee        Employee  @relation(fields: [employeeId], references: [id])
  leaveTypeId     String
  leaveType       LeaveType @relation(fields: [leaveTypeId], references: [id])
  entityId        String
  entity          Entity    @relation(fields: [entityId], references: [id])
  fromDate        DateTime  @db.Date
  toDate          DateTime  @db.Date
  days            Float
  reason          String
  status          String    @default("PENDING")
  approvedBy      String?
  approvedAt      DateTime?
  rejectionReason String?
  isHalfDay       Boolean   @default(false)
  halfDayType     String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("leave_requests")
}

model ComplianceFiling {
  id          String    @id @default(cuid())
  entityId    String
  entity      Entity    @relation(fields: [entityId], references: [id])
  type        String
  month       Int
  year        Int
  dueDate     DateTime  @db.Date
  status      String    @default("PENDING")
  filedAt     DateTime?
  filedBy     String?
  referenceNo String?
  amount      Float?
  remarks     String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([entityId, type, month, year])
  @@map("compliance_filings")
}

model InvestmentDeclaration {
  id            String   @id @default(cuid())
  employeeId    String
  employee      Employee @relation(fields: [employeeId], references: [id])
  entityId      String
  entity        Entity   @relation(fields: [entityId], references: [id])
  financialYear String
  regime        String   @default("NEW")

  // Section 80C (max ₹1,50,000)
  sec80C_ppf      Float @default(0)
  sec80C_elss     Float @default(0)
  sec80C_lic      Float @default(0)
  sec80C_nsc      Float @default(0)
  sec80C_tuition  Float @default(0)
  sec80C_homeLoan Float @default(0)
  sec80C_fd       Float @default(0)
  sec80C_sukanya  Float @default(0)
  sec80C_other    Float @default(0)

  // Section 80D (Health Insurance)
  sec80D_self    Float @default(0)
  sec80D_parents Float @default(0)

  // Section 24(b) — Home Loan Interest
  sec24_homeLoanInterest Float @default(0)

  // Other sections
  sec80E_eduLoan  Float @default(0)
  sec80G_donation Float @default(0)
  nps_80CCD       Float @default(0)

  // HRA Exemption inputs
  hraRentPaid Float   @default(0)
  hraMetro    Boolean @default(false)

  // Computed totals
  total80C        Float  @default(0)
  totalDeductions Float  @default(0)
  status          String @default("DECLARED")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([employeeId, financialYear])
  @@map("investment_declarations")
}
