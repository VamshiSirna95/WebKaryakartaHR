generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Entity {
  id               String            @id @default(cuid())
  code             String            @unique
  name             String
  legalName        String?
  pfCode           String?
  esiCode          String?
  ptCode           String?
  gstin            String?
  locations        Location[]
  employees        Employee[]
  attendanceMonths AttendanceMonth[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

model Location {
  id        String     @id @default(cuid())
  code      String
  name      String
  entityId  String
  entity    Entity     @relation(fields: [entityId], references: [id])
  employees Employee[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@unique([entityId, code])
}

model Department {
  id             String          @id @default(cuid())
  name           String          @unique
  subDepartments SubDepartment[]
  employees      Employee[]
  createdAt      DateTime        @default(now())
}

model SubDepartment {
  id           String     @id @default(cuid())
  name         String
  departmentId String
  department   Department @relation(fields: [departmentId], references: [id])
  employees    Employee[]
  createdAt    DateTime   @default(now())

  @@unique([departmentId, name])
}

model Designation {
  id        String     @id @default(cuid())
  name      String     @unique
  employees Employee[]
  createdAt DateTime   @default(now())
}

model ShiftCode {
  id        String     @id @default(cuid())
  code      String     @unique
  name      String
  startTime String?
  endTime   String?
  employees Employee[]
  createdAt DateTime   @default(now())
}

model Employee {
  id               String    @id @default(cuid())
  employeeCode     String    @unique
  fullName         String
  careOfName       String?
  careOfRelation   String?
  dateOfBirth      DateTime?
  gender           String?
  bloodGroup       String?
  aadhaarNumber    String?
  panNumber        String?
  contact1         String?
  contact2         String?
  presentAddress   String?
  permanentAddress String?
  profilePhotoUrl  String?

  bankAccountNo String?
  bankName      String?
  bankIfsc      String?
  bankBranch    String?

  uanNumber String?
  uanStatus String @default("NOT_GENERATED")
  esiNumber String?
  esiStatus String @default("NOT_GENERATED")

  entityId             String
  entity               Entity         @relation(fields: [entityId], references: [id])
  locationId           String
  location             Location       @relation(fields: [locationId], references: [id])
  departmentId         String
  department           Department     @relation(fields: [departmentId], references: [id])
  subDepartmentId      String?
  subDepartment        SubDepartment? @relation(fields: [subDepartmentId], references: [id])
  designationId        String
  designation          Designation    @relation(fields: [designationId], references: [id])
  shiftCodeId          String?
  shiftCode            ShiftCode?     @relation(fields: [shiftCodeId], references: [id])
  dateOfJoining        DateTime
  dateOfJoiningCurrent DateTime?
  bonusMonth           Int?
  appraisalDate        DateTime?
  status               String         @default("ACTIVE")
  separationDate       DateTime?

  salary       Decimal @default(0) @db.Decimal(12, 2)
  basic        Decimal @default(0) @db.Decimal(12, 2)
  hra          Decimal @default(0) @db.Decimal(12, 2)
  specialAllow Decimal @default(0) @db.Decimal(12, 2)
  travelAllow  Decimal @default(0) @db.Decimal(12, 2)

  attendanceRecords AttendanceRecord[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([entityId])
  @@index([locationId])
  @@index([departmentId])
  @@index([status])
}

model AttendanceMonth {
  id       String   @id @default(cuid())
  year     Int
  month    Int
  entityId String
  entity   Entity   @relation(fields: [entityId], references: [id])
  status   String   @default("OPEN")
  lockedAt DateTime?
  lockedBy String?
  records  AttendanceRecord[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([year, month, entityId])
}

model AttendanceRecord {
  id                String          @id @default(cuid())
  attendanceMonthId String
  attendanceMonth   AttendanceMonth @relation(fields: [attendanceMonthId], references: [id])
  employeeId        String
  employee          Employee        @relation(fields: [employeeId], references: [id])

  day1  String?
  day2  String?
  day3  String?
  day4  String?
  day5  String?
  day6  String?
  day7  String?
  day8  String?
  day9  String?
  day10 String?
  day11 String?
  day12 String?
  day13 String?
  day14 String?
  day15 String?
  day16 String?
  day17 String?
  day18 String?
  day19 String?
  day20 String?
  day21 String?
  day22 String?
  day23 String?
  day24 String?
  day25 String?
  day26 String?
  day27 String?
  day28 String?
  day29 String?
  day30 String?
  day31 String?

  workedDays  Decimal? @db.Decimal(5, 1)
  weekOffs    Int?
  otDays      Decimal? @db.Decimal(5, 1)
  payableDays Decimal? @db.Decimal(5, 1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([attendanceMonthId, employeeId])
  @@index([employeeId])
}

model Holiday {
  id        String   @id @default(cuid())
  date      DateTime @db.Date
  name      String
  entityId  String?
  createdAt DateTime @default(now())

  @@unique([date, entityId])
}
